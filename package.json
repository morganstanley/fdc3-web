        "@nx/jest": "20.6.2",
        "@nx/web": "20.6.2",
        "@nx/webpack": "20.6.2",
        "@swc-node/register": "^1.10.9",
        "@swc/core": "^1.11.8",
        "@types/eslint": "^8.56.12",
        "@types/eslint-scope": "^3.7.7",
        "@types/estree": "^1.0.6",
        "@types/jest": "^29.5.14",
        "@types/node": "^20.17.24",
